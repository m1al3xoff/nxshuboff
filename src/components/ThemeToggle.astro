---
<button id="tbtn" aria-label="Cambia tema">
  <i class="bx bx-moon"></i>
</button>

<style>
  button {
    background: none;
    border: 1px solid var(--border);
    color: var(--text);
    cursor: pointer;
    padding: 0.4rem;
    border-radius: 6px;
    display: flex;
    align-items: center;
    font-size: 1.1rem;
  }
  button:hover { border-color: var(--accent); color: var(--accent); }
</style>

<script>
  const b = document.getElementById('tbtn');
  const i = b.querySelector('i');
  const u = () => { i.className = window.__theme === 'dark' ? 'bx bx-sun' : 'bx bx-moon'; };
  u();
  b.addEventListener('click', () => {
    const x = window.__theme === 'dark' ? 'light' : 'dark';
    window.__setTheme(x);
    u();
  });
</script>
